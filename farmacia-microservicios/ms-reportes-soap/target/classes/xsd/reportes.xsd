<?xml version="1.0" encoding="UTF-8"?>
<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema"
           xmlns:tns="http://farmacia.com/reportes"
           targetNamespace="http://farmacia.com/reportes"
           elementFormDefault="qualified">

    <xs:element name="getReporteRequest">
        <xs:complexType>
            <xs:sequence>
                <xs:element name="tipo" type="xs:string" minOccurs="0"/>
            </xs:sequence>
        </xs:complexType>
    </xs:element>

    <xs:element name="getReporteResponse">
        <xs:complexType>
            <xs:sequence>
                <xs:element name="totalVentas" type="xs:int"/>
                <xs:element name="ingresoTotal" type="xs:double"/>
                <xs:element name="totalUnidades" type="xs:int"/>
            </xs:sequence>
        </xs:complexType>
    </xs:element>

    <xs:element name="registrarVentaRequest">
        <xs:complexType>
            <xs:sequence>
                <xs:element name="ventaId" type="xs:string"/>
                <xs:element name="medicamento" type="xs:string"/>
                <xs:element name="cantidad" type="xs:int"/>
                <xs:element name="total" type="xs:double"/>
                <xs:element name="cliente" type="xs:string"/>
            </xs:sequence>
        </xs:complexType>
    </xs:element>

    <xs:element name="registrarVentaResponse">
        <xs:complexType>
            <xs:sequence>
                <xs:element name="status" type="xs:string"/>
                <xs:element name="mensaje" type="xs:string"/>
            </xs:sequence>
        </xs:complexType>
    </xs:element>
</xs:schema>
